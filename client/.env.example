# ──────────────────────────────────────────────────────────────────
# Finwise — Environment Variables
# Copy this file to .env.local and fill in your Supabase project values.
# Find these in: Supabase Dashboard → Project Settings → API
# ──────────────────────────────────────────────────────────────────

# Your project URL — looks like https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your project's anon/public key — safe to expose in the browser
# (RLS policies protect your data, not this key)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
