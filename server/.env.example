# Copy to server/.env and fill in. Used by the API when running `npm run dev` from repo root.
# Plaid: https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | production  (defaults to sandbox)
PLAID_ENV=sandbox
# Shown in Plaid Link (max 30 chars)
PLAID_CLIENT_NAME=Finwise

# Supabase service role — Dashboard → Project Settings → API → service_role (secret).
# Required to verify the user JWT and to write accounts / encrypted Plaid items server-side.
# Never expose this key in the browser or in VITE_* env vars.
#
# You can omit SUPABASE_URL if the same value is already in client/.env.local as VITE_SUPABASE_URL
# — the API loads client env files automatically when starting via `npm run dev`.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional; defaults to 3001
# PORT=3001
